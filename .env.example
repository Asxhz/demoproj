# App database (Neon in production, local Postgres in dev)
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/claudex

# Session cookie signing
SESSION_SECRET=

# Public app URL (used for OAuth callbacks and invite links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- GitHub OAuth (Connect GitHub) ---
# Create an OAuth app at https://github.com/settings/developers
# Authorization callback URL: <NEXT_PUBLIC_APP_URL>/api/integrations/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Discord bot ---
# Bot token + the public key from the Discord developer portal.
# Interactions endpoint URL: <NEXT_PUBLIC_APP_URL>/api/integrations/discord/interactions
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=
DISCORD_APPLICATION_ID=
DISCORD_GUILD_ID=
DISCORD_VOICE_CHANNEL_ID=
# Optional: text channel to post signup + meeting links into
DISCORD_ANNOUNCE_CHANNEL_ID=

# --- Browserbase (cloud browser sessions) ---
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
