# App database (Neon in production, local Postgres in sandbox)
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/claudex

# Neon read-only source for uTrace sandbox seeding
SOURCE_DATABASE_READONLY_URL=

# Session cookie signing
SESSION_SECRET=

# uTrace adapter HMAC secret (shared with uTrace)
UTRACE_ADAPTER_SECRET=

# uTrace product link HMAC secret
UTRACE_PRODUCT_LINK_SECRET=

# uTrace client ID (public, used in product link callback)
NEXT_PUBLIC_UTRACE_CLIENT_ID=

# uTrace API base URL
UTRACE_API_BASE_URL=https://api.utrace.dev
